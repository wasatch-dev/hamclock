#
# HamClock desktop file suitable for autostarting or manual starting.
#
# Setup icons:
#   mkdir -p ~/.local/share/icons ~/.local/share/applications/
#   cp hamclock.png ~/.local/share/icons/
#   cp hamclock.png ~/.local/share/applications/
#
# Setup autostart:
#   cp hamclock.desktop ~/.config/autostart/
#   chmod +x ~/.config/autostart/hamclock.desktop
#
[Desktop Entry]
Name=HamClock
GenericName=Amateur Radio Clock
Comment=Scientific clock for amateur radio operators
# This shell command waits for a graphical display (X11 or Wayland) 
# then waits 5 seconds for the window manager to settle before launching.
Exec=sh -c 'until [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; do sleep 1; done; sleep 5; exec /usr/local/bin/hamclock'
Icon=hamclock
Terminal=false
Type=Application
Categories=HamRadio


# --- Cross-Distro Compatibility Settings ---

# For GNOME (Fedora/Debian default):
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=5

# For KDE (Fedora/Debian KDE spins):
# Tells KDE to wait until the panel/taskbar is loaded
X-KDE-autostart-after=panel

# For MATE/XFCE:
X-MATE-Autostart-enabled=true
